{
  "name": "com.johnhammerlund.discordadminbot",
  "version": "1.0.0",
  "private": true,
  "description": "Stream Deck plugin for Discord voice channel admin controls",
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "watch": "rollup -c --bundleConfigAsCjs -w --watch.onEnd=\"streamdeck restart com.johnhammerlund.discordadminbot\""
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "discord.js": "^14.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "rollup": "^4.27.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
